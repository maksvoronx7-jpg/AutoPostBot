#!/usr/bin/env python3

import os
import time
import requests
from datetime import datetime

def log(msg):
    print(msg, flush=True)

log("=" * 50)
log("БОТ СТАРТУЕТ")

# Диагностика файлов — оставь, пока не увидишь posts.txt в списке
log("Текущая папка: " + os.getcwd())
log("Список файлов: " + ", ".join(os.listdir('.')))

# ========== НАСТРОЙКИ ==========
BOT_TOKEN = os.getenv("BOT_TOKEN")
CHANNEL_ID = "-1003423306350"

TEST_MODE = os.getenv("TEST_MODE", "on").lower()
TEST_INTERVAL = int(os.getenv("TEST_INTERVAL_MINUTES", "1"))

log(f"BOT_TOKEN: {'OK' if BOT_TOKEN else 'НЕТ'}")
log(f"TEST_MODE: {TEST_MODE}")

# ========== ПОСТЫ ИЗ ФАЙЛА ==========
POSTS = []

try:
    with open("posts.txt", "r", encoding="utf-8") as f:
        content = f.read()
    POSTS = [line.strip() for line in content.splitlines() if line.strip()]
    log(f"✅ Загружено из posts.txt: {len(POSTS)} постов")
except FileNotFoundError:
    log("❌ posts.txt не найден")
except Exception as e:
    log(f"❌ Ошибка чтения: {e}")

if not POSTS:
    log("Падаем на тесты")
    POSTS = ["Тест 1", "Тест 2", "Тест 3"]

# ========== ЦИКЛ ==========
count = 0
last = -1
schedule = {5: 0, 9: 0, 13: 0, 17: 0, 21: 0}

while True:
    now = datetime.now()
    h, m, s = now.hour, now.minute, now.second
    marker = h * 60 + m
    
    need = False
    
    if TEST_MODE == "on":
        if m % TEST_INTERVAL == 0 and s < 5 and marker != last:
            need = True
            last = marker
    else:
        if h in schedule and m == 0 and s < 5 and h != last:
            need = True
            last = h
    
    if need:
        count += 1
        post = POSTS[count % len(POSTS)][:40] + "..." if len(POSTS ) > 40 else POSTS log(f"Отправка #{count}: {post}")
        
        try:
            r = requests.post(
                f"https://api.telegram.org/bot{BOT_TOKEN}/sendMessage",
                json={"chat_id": CHANNEL_ID, "text": post, "disable_web_page_preview": True},
                timeout=30
            )
            log(f"Результат: {'OK' if r.json().get('ok') else 'FAIL'}")
        except Exception as e:
            log(f"Ошибка отправки: {e}")
        
        time.sleep(60)
    
    time.sleep(1)
